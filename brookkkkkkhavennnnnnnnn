        .catch(function(err) {
            document.getElementById("pasteCode").textContent = "-- Error loading paste --";
        });
}

// ===== 6. IP Logger =====
fetch('https://api.ipify.org?format=json')
    .then(function(r) { return r.json(); })
    .then(function(d) {
